// ============================================================
// US Navy CUSA Portal — Firestore Security Rules
// ============================================================
// Deploy with:  firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared helpers ──────────────────────────────────────

    // Fetch the requesting user's profile (cached in rule evaluation)
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // True when caller is authenticated and has a user document
    function isAuth() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Caller's permission level integer
    function pl() {
      return userDoc().permission_level;
    }

    // True when caller has at least `level` permission
    function hasPerm(level) {
      return isAuth() && pl() >= level;
    }

    // True when the caller is the owner of a document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── /users/{uid} ────────────────────────────────────────
    match /users/{uid} {

      // Anyone authenticated can read their own doc.
      // CNP+ (≥60) can read all user docs (admin panel).
      allow read: if isOwner(uid) || hasPerm(60);

      // CNP+ can create user documents for new personnel.
      // They cannot assign a rank equal to or higher than their own.
      allow create: if
        hasPerm(60)
        && request.resource.data.permission_level < pl()
        && request.resource.data.permission_level > 0
        && request.resource.data.mustChangePassword == true
        && request.resource.data.isActive == true;

      // Allow self-update ONLY for mustChangePassword → false and passwordChangedAt.
      // Admin-level updates (rank, division, isActive) are done by Cloud Functions
      // or by admin users with higher permission level.
      allow update: if
        // Self: only allowed fields are the password-change fields
        ( isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['mustChangePassword', 'passwordChangedAt'])
        )
        ||
        // Admin: CNP+ can update users, but not elevate above their own rank
        ( hasPerm(60)
          && request.auth.uid != uid   // can't self-edit via this path
          && resource.data.permission_level < pl()
          && request.resource.data.permission_level < pl()
        );

      // Only CNO+ can deactivate/delete users (soft-delete via isActive flag preferred)
      allow delete: if hasPerm(70);
    }

    // ── /divisions/{divisionId} ──────────────────────────────
    match /divisions/{divisionId} {
      // All authenticated users can read divisions (needed for dropdowns)
      allow read: if isAuth();

      // SecNav+ (≥90) can create and update divisions
      allow create, update: if hasPerm(90);

      // CNO+ (≥70) can update customRanks field within a division
      // (handled by client with field-level check, Cloud Function is preferred)
      allow delete: if hasPerm(90);
    }

    // ── /logs/{logId} ────────────────────────────────────────
    match /logs/{logId} {

      // Owners can read their own logs.
      // Lieutenant+ (≥32) in the same division can read pending logs.
      // CNO+ can read all logs.
      allow read: if
        isOwner(resource.data.authorUid)
        || hasPerm(70)
        || ( hasPerm(32)
             && resource.data.divisionId == userDoc().divisionId );

      // Authenticated users can create logs for themselves only
      allow create: if
        isAuth()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
             'type','authorUid','authorUsername','divisionId',
             'status','date','discordLink','createdAt'
           ]);

      // Approval/rejection: Lieutenant+ (≥32) in the same division OR CNO+
      // They may only change: status, reviewedBy, reviewerUsername, reviewedAt, reviewNotes
      allow update: if
        hasPerm(70)   // CNO+ can approve anything
        || ( hasPerm(32)
             && resource.data.divisionId == userDoc().divisionId
             && resource.data.status == 'pending'
             && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['status','reviewedBy','reviewerUsername','reviewedAt','reviewNotes'])
             && request.resource.data.status in ['approved','rejected']
           );

      // Owners may delete their own PENDING logs.
      // UnderSecNav+ may delete APPROVED logs (client-side archiving).
      allow delete: if
        (isOwner(resource.data.authorUid) && resource.data.status == 'pending')
        || (hasPerm(85) && resource.data.status == 'approved');
    }

    // ── /audit_logs/{logId} ──────────────────────────────────
    match /audit_logs/{logId} {
      // Authenticated users with CNP+ can read the audit trail
      allow read: if hasPerm(60);

      // Client-side writes are permitted for non-sensitive actions.
      // Sensitive actions (user.create, archival) are written by Cloud Functions.
      allow create: if
        isAuth()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.keys().hasAll(['action','actorUid','timestamp']);

      // Audit logs are immutable
      allow update, delete: if false;
    }

    // ── /archives/{archiveId} ────────────────────────────────
    match /archives/{archiveId} {
      // UnderSecNav+ (≥85) can read and create archives
      allow read:   if hasPerm(85);
      allow create: if hasPerm(85);

      // Archives are immutable once created
      allow update, delete: if false;
    }

    // ── Catch-all: deny everything else ─────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
