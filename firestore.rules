// ============================================================
// US Navy CUSA Portal — Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Core helpers ─────────────────────────────────────────

    function authed() {
      return request.auth != null;
    }

    function selfDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // int() coercion handles both number 100 and string "100" stored in Firestore
    function pl() {
      return authed() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? int(selfDoc().get('permission_level', 0))
        : 0;
    }

    // Treat missing/null division as '' so same-division checks stay consistent
    function divId() {
      return authed() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? selfDoc().get('divisionId', '') == null
          ? ''
          : string(selfDoc().get('divisionId', ''))
        : '';
    }

    // HQ = CNP+ (≥60) or Divisionless — can see across all divisions
    function isHQ() {
      return pl() >= 60 || divId() == 'ndvl' || divId() == '';
    }

    function divisionHQFlag(did) {
      return did != ''
        && exists(/databases/$(database)/documents/divisions/$(did))
        && get(/databases/$(database)/documents/divisions/$(did)).data.get('isHeadquarters', false) == true;
    }

    // Path /divisions/{divisionId} — is this doc the Headquarters division?
    function divisionDocIsHQ(did) {
      return did == 'hq' || divisionHQFlag(did);
    }

    // OCNP / OCNO — additional affiliation on user doc (list of string ids)
    function isPersonnelOfficeStaff() {
      return authed() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && selfDoc().get('personnelOffices', []) is list
        && selfDoc().get('personnelOffices', []).hasAny(['ocnp', 'ocno']);
    }

    // Update division metadata: SecNav+ any; CNP+ any non-HQ; Admiral+ own division only (not NDVL)
    function canUpdateDivisionDoc(did) {
      return did != '' && did != 'ndvl' && (
        pl() >= 90
        || (pl() >= 60 && !divisionDocIsHQ(did))
        || (pl() >= 50 && divId() == did && divId() != '')
      );
    }

    function quotaIsAdministrator() {
      return selfDoc().get('rankId', '') == 'administrator';
    }

    // Caller's home division is Headquarters (doc flag or id hq)
    function quotaUserDivisionIsHQ() {
      return divId() != '' && (divId() == 'hq' || divisionHQFlag(divId()));
    }

    // Administrator: all. HQ division target: SecNav+ only. Else: RDML+ own div, SecNav+, or HQ (non-SecNav) cross-division.
    function canManageQuotaForDivision(did) {
      return did != '' && did != 'ndvl' && (
        quotaIsAdministrator()
        || (divisionHQFlag(did) && (pl() >= 90 || selfDoc().get('rankId', '') == 'secnav'))
        || (!divisionHQFlag(did) && pl() >= 44 && (
          divId() == did
          || pl() >= 90
          || selfDoc().get('rankId', '') == 'secnav'
          || (quotaUserDivisionIsHQ() && selfDoc().get('rankId', '') != 'secnav')
        ))
      );
    }

    // Quota request doc read — matches js/ranks.js PERM (CNP = 60, SecNav tier = 90)
    function quotaRequestDivisionId() {
      return resource.data.get('divisionId', '');
    }

    // SecNav+ (or rank secnav): any division including Headquarters
    function quotaCanReadAnyQuotaRequest() {
      return quotaIsAdministrator() || pl() >= 90 || selfDoc().get('rankId', '') == 'secnav';
    }

    // CNP through Under SecNav: read non–Headquarters requests from any division (not HQ quota pipeline)
    function quotaCanReadNonHQQuotaRequestGlobally() {
      let rid = quotaRequestDivisionId();
      return rid != '' && pl() >= 60 && pl() < 90 && !divisionHQFlag(rid);
    }

    // RDML+ in own division; if that division is HQ, SecNav+ only (same as manage policy)
    function quotaCanReadOwnDivisionQuotaRequest() {
      return pl() >= 44 && divId() != ''
        && quotaRequestDivisionId() == divId()
        && (!divisionHQFlag(divId()) || pl() >= 90 || selfDoc().get('rankId', '') == 'secnav');
    }

    // ── /users/{uid} ─────────────────────────────────────────
    match /users/{uid} {

      // Own doc always readable; HQ (CNP+) or same division can read others
      // OCNP/OCNO staff may read Navy Divisionless personnel
      allow read: if authed() && (
        request.auth.uid == uid
        || pl() >= 60
        || divId() == resource.data.get('divisionId', '__none__')
        || (
          isPersonnelOfficeStaff()
          && resource.data.get('divisionId', '') == 'ndvl'
        )
      );

      // CNP+ can create user docs for new personnel
      // OCNP/OCNO staff (MCPO+): create Navy Divisionless accounts only
      // Cannot assign rank >= own level
      allow create: if authed()
        && int(request.resource.data.get('permission_level', 0)) < pl()
        && int(request.resource.data.get('permission_level', 0)) > 0
        && request.resource.data.get('mustChangePassword', false) == true
        && request.resource.data.get('isActive', false) == true
        && (
          (
            pl() >= 60
          )
          || (
            pl() >= 42
            && isPersonnelOfficeStaff()
            && request.resource.data.get('divisionId', '') == 'ndvl'
          )
        );

      // Self: only password-change fields
      // CNP+ admin: rank/division/active, cannot touch docs with rank >= own
      // OCNP/OCNO: edit Navy Divisionless users only (division stays ndvl); cannot change personnelOffices
      allow update: if authed() && (
        (
          request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['mustChangePassword', 'passwordChangedAt'])
        )
        ||
        (
          pl() >= 60
          && request.auth.uid != uid
          && int(resource.data.get('permission_level', 0)) < pl()
          && int(request.resource.data.get('permission_level', 0)) < pl()
        )
        ||
        (
          pl() >= 42
          && isPersonnelOfficeStaff()
          && request.auth.uid != uid
          && resource.data.get('divisionId', '') == 'ndvl'
          && request.resource.data.get('divisionId', '') == 'ndvl'
          && int(resource.data.get('permission_level', 0)) < pl()
          && int(request.resource.data.get('permission_level', 0)) < pl()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly([
                 'rankId', 'rankName', 'rankShort', 'permission_level',
                 'divRankId', 'divRankName', 'divRankShort', 'divRankTier', 'mappedRankId',
                 'divisionId', 'divisionName', 'isActive', 'email',
                 'updatedAt', 'updatedBy'
               ])
        )
      );

      allow delete: if authed() && pl() >= 70;
    }

    // ── /divisions/{divisionId} ──────────────────────────────
    match /divisions/{divisionId} {
      // All authenticated users can read (needed for dropdowns)
      allow read: if authed();

      allow create: if authed() && pl() >= 90;
      allow update: if authed() && canUpdateDivisionDoc(divisionId);
      allow delete: if authed() && pl() >= 90;
    }

    // ── /logs/{logId} ────────────────────────────────────────
    match /logs/{logId} {

      // Own logs always readable
      // CNP+ (HQ) read all
      // MCPO+ (≥42) read same-division logs (incl. pending — for review UIs)
      // Any member with a division can read approved logs in that division (dashboard stats, transparency)
      allow read: if authed() && (
        resource.data.authorUid == request.auth.uid
        || pl() >= 60
        || (pl() >= 42 && resource.data.get('divisionId', '') == divId())
        || (
          divId() != ''
          && resource.data.get('divisionId', '') == divId()
          && resource.data.get('status', '') == 'approved'
        )
      );

      // Any authenticated user can create logs for themselves
      allow create: if authed()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['type', 'authorUid', 'status', 'createdAt'])
        && (!request.resource.data.keys().hasAny(['attendeeUids']) || (
          request.resource.data.type == 'event'
          && request.resource.data.attendeeUids is list
          && request.resource.data.attendeeUids.size() <= 40
        ));

      // Approve/reject:
      //   CNP+ (≥60) can approve any log
      //   MCPO+ (≥42) can approve/reject pending logs in their own division
      //   MCPO+ may set attendeeUids / eventDefinitionId on pending event logs (quota)
      allow update: if authed() && (
        pl() >= 60
        || (
          pl() >= 42
          && resource.data.status == 'pending'
          && resource.data.get('divisionId', '') == divId()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status','reviewedBy','reviewerUsername','reviewedAt','reviewNotes'])
          && request.resource.data.status in ['approved','rejected']
        )
        || (
          pl() >= 42
          && resource.data.status == 'pending'
          && resource.data.get('divisionId', '') == divId()
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['attendeeUids','eventDefinitionId'])
        )
      );

      // Owner can delete own pending logs
      // UnderSecNav+ (≥85) can delete any approved log (for global archive)
      // Admiral+ (≥50) can delete approved logs in own division (for divisional archive)
      allow delete: if authed() && (
        (resource.data.authorUid == request.auth.uid && resource.data.status == 'pending')
        || (pl() >= 85 && resource.data.status == 'approved')
        || (pl() >= 50 && resource.data.status == 'approved'
            && resource.data.get('divisionId', '') == divId()
            && divId() != '')
      );
    }

    // ── /audit_logs/{logId} ──────────────────────────────────
    match /audit_logs/{logId} {
      // CNP+ can read the audit trail
      allow read: if authed() && pl() >= 60;

      // Any authenticated user can write their own audit entries
      allow create: if authed()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.keys().hasAll(['action', 'actorUid', 'timestamp']);

      // Audit logs are immutable
      allow update, delete: if false;
    }

    // ── /archives/{archiveId} ────────────────────────────────
    match /archives/{archiveId} {
      // CNP+ (≥60) read all; any division member reads own division's archives (for stats)
      allow read: if authed() && (
        pl() >= 60
        || (divId() != '' && resource.data.get('divisionId', '') == divId())
      );
      // UnderSecNav+ (≥85) archive any/all; Admiral+ (≥50) archive own division only
      allow create: if authed() && (
        pl() >= 85
        || (pl() >= 50 && divId() != ''
            && request.resource.data.get('divisionId', '') == divId()
            && request.resource.data.divisionId != null)
      );
      allow update, delete: if false;
    }

    // ── /quota_requests/{id} — client + rules (Spark / no Cloud Functions) ──
    match /quota_requests/{requestId} {
      allow read: if authed() && (
        resource.data.get('requesterUid', '') == request.auth.uid
        || quotaCanReadAnyQuotaRequest()
        || quotaCanReadNonHQQuotaRequestGlobally()
        || quotaCanReadOwnDivisionQuotaRequest()
      );
      allow create: if authed()
        && request.resource.data.requesterUid == request.auth.uid
        && request.resource.data.divisionId == divId()
        && divId() != '' && divId() != 'ndvl'
        && request.resource.data.status == 'pending'
        && request.resource.data.requestType in ['MDQRA', 'LOA']
        && request.resource.data.keys().hasAll(['requestType', 'requesterUid', 'divisionId', 'status', 'createdAt'])
        && (
          (request.resource.data.requestType == 'MDQRA'
            && request.resource.data.reductionPercent is number
            && request.resource.data.reductionPercent > 0
            && request.resource.data.reductionPercent <= 100)
          || (request.resource.data.requestType == 'LOA'
            && request.resource.data.loaStart is string
            && request.resource.data.loaEnd is string)
        );
      allow update: if authed()
        && canManageQuotaForDivision(resource.data.divisionId)
        && resource.data.status == 'pending'
        && request.resource.data.status in ['approved', 'rejected']
        && request.resource.data.decidedByUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'decidedAt', 'decidedByUid', 'decidedByUsername', 'decisionNotes']);
      allow delete: if false;
    }

    // ── /quota_modifiers/{id} — legacy (Cloud-created only); read for quota math ──
    match /quota_modifiers/{modId} {
      allow read: if authed() && (
        resource.data.get('userId', '') == request.auth.uid
        || pl() >= 60
        || (pl() >= 44 && resource.data.get('divisionId', '') == divId() && divId() != '')
      );
      allow create, update, delete: if false;
    }

    // ── /quota_attendance/{id} — reviewers sync on log approval ──
    match /quota_attendance/{attId} {
      allow read: if authed() && (
        resource.data.get('userId', '') == request.auth.uid
        || pl() >= 60
        || (pl() >= 42 && resource.data.get('divisionId', '') == divId() && divId() != '')
      );
      allow create: if authed() && pl() >= 42
        && exists(/databases/$(database)/documents/logs/$(request.resource.data.logId))
        && get(/databases/$(database)/documents/logs/$(request.resource.data.logId)).data.status == 'approved'
        && request.resource.data.divisionId
             == get(/databases/$(database)/documents/logs/$(request.resource.data.logId)).data.divisionId
        && (pl() >= 60
            || get(/databases/$(database)/documents/logs/$(request.resource.data.logId)).data.get('divisionId', '')
               == divId());
      allow delete: if authed() && pl() >= 42
        && (pl() >= 60 || resource.data.get('divisionId', '') == divId());
      allow update: if false;
    }

    // ── /reform_snapshots/{id} + entries ─────────────────────
    match /reform_snapshots/{snapId} {
      allow read: if authed() && (
        pl() >= 60
        || (resource.data.get('divisionId', '') == divId() && divId() != '')
      );
      allow create: if authed()
        && canManageQuotaForDivision(request.resource.data.divisionId)
        && request.resource.data.keys().hasAll([
          'divisionId', 'weekKey', 'periodStart', 'periodEnd', 'computedAt', 'entryCount'
        ]);
      allow update, delete: if false;

      match /entries/{entryId} {
        allow read: if authed() && (
          pl() >= 60
          || (get(/databases/$(database)/documents/reform_snapshots/$(snapId)).data.get('divisionId', '') == divId()
              && divId() != '')
        );
        allow create: if authed()
          && canManageQuotaForDivision(
            get(/databases/$(database)/documents/reform_snapshots/$(snapId)).data.divisionId
          )
          && request.resource.data.keys().hasAll([
            'userId', 'requiredTotal', 'completedTotal', 'deficit', 'completionPct'
          ]);
        allow update, delete: if false;
      }
    }

    // ── /quota_policies — commanders + HQ authority ───────────
    match /quota_policies/{policyId} {
      allow read: if authed();
      allow create: if authed()
        && canManageQuotaForDivision(request.resource.data.divisionId)
        && request.resource.data.keys().hasAll(['divisionId', 'rankId', 'periodKind', 'effectiveFrom', 'rules'])
        && request.resource.data.rules is list;
      allow update: if authed()
        && canManageQuotaForDivision(resource.data.divisionId)
        && request.resource.data.divisionId == resource.data.divisionId;
      allow delete: if authed() && canManageQuotaForDivision(resource.data.divisionId);
    }

    match /event_definitions/{defId} {
      allow read: if authed();
      allow create: if authed()
        && canManageQuotaForDivision(request.resource.data.divisionId)
        && request.resource.data.keys().hasAll(['divisionId', 'key', 'label']);
      allow update: if authed()
        && canManageQuotaForDivision(resource.data.divisionId)
        && request.resource.data.divisionId == resource.data.divisionId;
      allow delete: if authed() && canManageQuotaForDivision(resource.data.divisionId);
    }

    // ── Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
