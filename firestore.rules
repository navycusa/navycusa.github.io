// ============================================================
// US Navy CUSA Portal — Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Core helpers ─────────────────────────────────────────

    function authed() {
      return request.auth != null;
    }

    function selfDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // int() coercion handles both number 100 and string "100" stored in Firestore
    function pl() {
      return authed() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? int(selfDoc().get('permission_level', 0))
        : 0;
    }

    function divId() {
      return authed() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? selfDoc().get('divisionId', '')
        : '';
    }

    // HQ = CNP+ (≥60) or Divisionless — can see across all divisions
    function isHQ() {
      return pl() >= 60 || divId() == 'ndvl' || divId() == '';
    }

    // ── /users/{uid} ─────────────────────────────────────────
    match /users/{uid} {

      // Own doc always readable; HQ (CNP+) or same division can read others
      allow read: if authed() && (
        request.auth.uid == uid
        || pl() >= 60
        || divId() == resource.data.get('divisionId', '__none__')
      );

      // CNP+ can create user docs for new personnel
      // Cannot assign rank >= own level
      allow create: if authed()
        && pl() >= 60
        && int(request.resource.data.get('permission_level', 0)) < pl()
        && int(request.resource.data.get('permission_level', 0)) > 0
        && request.resource.data.get('mustChangePassword', false) == true
        && request.resource.data.get('isActive', false) == true;

      // Self: only password-change fields
      // CNP+ admin: rank/division/active, cannot touch docs with rank >= own
      allow update: if authed() && (
        (
          request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['mustChangePassword', 'passwordChangedAt'])
        )
        ||
        (
          pl() >= 60
          && request.auth.uid != uid
          && int(resource.data.get('permission_level', 0)) < pl()
          && int(request.resource.data.get('permission_level', 0)) < pl()
        )
      );

      allow delete: if authed() && pl() >= 70;
    }

    // ── /divisions/{divisionId} ──────────────────────────────
    match /divisions/{divisionId} {
      // All authenticated users can read (needed for dropdowns)
      allow read: if authed();

      // SecNav+ (≥90) manage divisions
      allow create, update: if authed() && pl() >= 90;
      allow delete:         if authed() && pl() >= 90;
    }

    // ── /logs/{logId} ────────────────────────────────────────
    match /logs/{logId} {

      // Own logs always readable
      // CNP+ (HQ) read all
      // MCPO+ (≥42, Divisional Command) read same-division logs
      allow read: if authed() && (
        resource.data.authorUid == request.auth.uid
        || pl() >= 60
        || (pl() >= 42 && resource.data.get('divisionId', '') == divId())
      );

      // Any authenticated user can create logs for themselves
      allow create: if authed()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll(['type', 'authorUid', 'status', 'createdAt']);

      // Approve/reject:
      //   CNP+ (≥60) can approve any log
      //   MCPO+ (≥42) can approve/reject pending logs in their own division
      allow update: if authed() && (
        pl() >= 60
        || (
          pl() >= 42
          && resource.data.status == 'pending'
          && resource.data.get('divisionId', '') == divId()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status','reviewedBy','reviewerUsername','reviewedAt','reviewNotes'])
          && request.resource.data.status in ['approved','rejected']
        )
      );

      // Owner can delete own pending logs
      // UnderSecNav+ (≥85) can delete approved logs for archiving
      allow delete: if authed() && (
        (resource.data.authorUid == request.auth.uid && resource.data.status == 'pending')
        || (pl() >= 85 && resource.data.status == 'approved')
      );
    }

    // ── /audit_logs/{logId} ──────────────────────────────────
    match /audit_logs/{logId} {
      // CNP+ can read the audit trail
      allow read: if authed() && pl() >= 60;

      // Any authenticated user can write their own audit entries
      allow create: if authed()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.keys().hasAll(['action', 'actorUid', 'timestamp']);

      // Audit logs are immutable
      allow update, delete: if false;
    }

    // ── /archives/{archiveId} ────────────────────────────────
    match /archives/{archiveId} {
      allow read:   if authed() && pl() >= 85;
      allow create: if authed() && pl() >= 85;
      allow update, delete: if false;
    }

    // ── Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
